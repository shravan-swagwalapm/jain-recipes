---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.tsx';
import IngredientFilter from '../components/IngredientFilter.tsx';
import recipes from '../data/recipes.json';

const base = import.meta.env.BASE_URL;

// Pass only the fields needed to keep client bundle small
const lightRecipes = recipes.map(({ slug, name, description, category, prepTime, cookTime, difficulty, servings, tags, ingredients }) => ({
  slug, name, description, category, prepTime, cookTime, difficulty, servings, tags, ingredients,
}));
---

<BaseLayout title="Search" description="Search Jain recipes by name, ingredient, or tag">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold mb-3">Find a Recipe</h1>
      <div class="mandala-divider justify-center max-w-xs mx-auto">
        <span class="text-gold text-xl">✦</span>
      </div>
    </div>

    <!-- Search by text -->
    <div class="mb-12">
      <SearchBar client:load recipes={lightRecipes} basePath={base} />
    </div>

    <!-- Divider -->
    <div class="flex items-center gap-4 my-10">
      <div class="flex-1 h-px bg-gradient-to-r from-transparent to-gold/30"></div>
      <span class="text-sm font-medium text-warm-gray-light uppercase tracking-wider">or filter by ingredient</span>
      <div class="flex-1 h-px bg-gradient-to-l from-transparent to-gold/30"></div>
    </div>

    <!-- Ingredient filter -->
    <IngredientFilter client:load recipes={lightRecipes} basePath={base} />
  </section>
</BaseLayout>
